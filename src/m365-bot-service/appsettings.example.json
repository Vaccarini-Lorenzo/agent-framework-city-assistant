{
  "A2A": {
    "Orchestrator": {
      "BaseUrl": "http://localhost:5197",
      "AgentCardPath": "/.well-known/agent-card.json",
      "FallbackMessageEndpointPath": "/agenta2a"
    }
  },
  "TokenValidation": {
    "Enabled": true,
    "Audiences": [
      "<BOT_APP_CLIENT_ID>"
    ],
    "TenantId": "<AZURE_AD_TENANT_ID>"
  },
  "AgentApplication": {
    "StartTypingTimer": true,
    "RemoveRecipientMention": false,
    "NormalizeMentions": false
  },
  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "ClientId": "<BOT_APP_CLIENT_ID>",
        "ClientSecret": "<BOT_APP_CLIENT_SECRET>",
        "AuthorityEndpoint": "https://login.microsoftonline.com/<AZURE_AD_TENANT_ID>",
        "Scopes": [
          "https://api.botframework.com/.default"
        ]
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],
  "MAF": {
    "Endpoint": "https://agentframework.microsoft.com"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}